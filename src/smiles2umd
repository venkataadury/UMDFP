def get_args():
    """Defines and parses command-line arguments."""
    parser = argparse.ArgumentParser(
        prog="smiles2umd",
        description="Convert SMILES blocks into Univeral Molecular Description (UMD) files. This is can be converted into the quick-lookup Univeral Molecular Format (UMF). Run umfmaker for this",
        epilog="Example: smiles2umd file.smi -c 12 -o output.umd "
    )

    # 1. Positional argument (Required)
    parser.add_argument("input_file", help="Path to the input file")

    # 2. Optional argument with a value (Default provided)
    parser.add_argument("-c", "--cpus", type=int, default=1, 
                        help="Number of CPUs to use (default: 1)")
    
    # 3. Optional argument with a value (Default provided)
    parser.add_argument("-o", "--output", type=str, default="output.umd", 
                        help="Output filename (default: output.umd)")
    
    # 3.5 Optional argument with a value (Default provided)
    parser.add_argument("-e", "--error", type=str, default="error.log", 
                        help="Error filename to write failed molecules (default: error.log)")
    
    
    # 4. Segment number (optional argument)
    parser.add_argument("-s", "--segment", type=int, default=-1, 
                        help="(Re)run a specific cut in a multi-CPU run. You will usually not need this")
    
    # 5. Optional argument with a value (Default provided)
    parser.add_argument("-b", "--batch_size", type=int, default=4096, 
                        help="Number of SMILES to load into memory at once. (Default: 4096)")


    # 6. Boolean flag (True if present, False if not)
    parser.add_argument("-f", "--force-overwrite", action="store_true",  help="Overwrite existing UMD files (if present)")

    return parser.parse_args()

def main():
    args = get_args()
    smifile=args.input_file
    cpus=int(args.cpus)
    segment=int(args.segment)
    errfile=args.error
    bsize=args.batch_size
    assert bsize>=cpus, "batch size must be greater than the number of CPUs used"
    
    outname=args.output
    if outname.endswith(".umd"):
        out_prefix=outname[:-4]
    else:
        out_prefix=outname
        outname+=".umd"
    
    errlog=open(errfile,"w")
    
    def process_block(seg):
        
        if cpus>1:
            o_filename=out_prefix+str(seg)+".umd"
        else:
            o_filename=outname
        
        outf=open(o_filename,"w")
        smiload=SequentialSMILESLoader(smifile,attach_names=True)
        while not smiload.ended:
            smis,names=smiload.getNext(bsize,as_smiles=True)
            for i in range(len(smis)):
                if (cpus>1) and (i%cpus!=seg): continue
                try:
                    raw_dump(smis[i],outf,names[i])
                except UndefinedStereochemistryError:
                    errlog.write(names[i]+"\n")
                    continue
                except RadicalsNotSupportedError:
                    errlog.write(names[i]+"\n")
                    continue
                except ValueError:
                    errlog.write(names[i]+"\n")
                    continue
        outf.close()
        return o_filename
    
    if segment>=0: process_block(segment)
    else:
        if cpus==1: process_block(0) # No parallelism
        else:
            from concurrent.futures import ThreadPoolExecutor
            with ThreadPoolExecutor(max_workers=cpus) as executor:
                written_files = list(executor.map(process_block,list(range(cpus))))
                final_file=open(outname,"w")
                for wf in written_files:
                    rf=open(wf,"r")
                    for l in rf: final_file.write(l)
                    rf.close()
                final_file.close()
    errlog.close()

if __name__ == "__main__": main()



