BOND_ORDERS={rdkit.Chem.rdchem.BondType.SINGLE: 2, rdkit.Chem.rdchem.BondType.DOUBLE: 4, rdkit.Chem.rdchem.BondType.AROMATIC: 3, rdkit.Chem.rdchem.BondType.TRIPLE: 6}


